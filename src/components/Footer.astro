---
/**
 * Site-wide footer. Renders the Fan Content Policy disclaimer required on
 * EVERY page (PRD.md §10, §7.8). The disclaimer text is verbatim-required by
 * the policy and must not be reworded.
 */
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <p class="footer-flourish" aria-hidden="true">&#10086;</p>
    <p class="disclaimer" role="contentinfo">
      This site is unofficial Fan Content permitted under the Fan Content
      Policy. Not approved/endorsed by Wizards. Portions of the materials used
      are property of Wizards of the Coast. &copy;Wizards of the Coast LLC.
    </p>
    <p class="colophon muted">
      The Avernus Archives &middot; {year} &middot; An original,
      non-commercial reference for the Ravenloft campaign setting. All lore is
      summarized in contributors' own words &mdash; no verbatim publisher text.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-7);
    border-top: 1px solid var(--accent-deep);
    background: var(--bg-inset);
    padding-block: var(--space-5);
    font-size: var(--step--1);
  }
  .footer-flourish {
    color: var(--accent-deep);
    text-align: center;
    font-size: var(--step-1);
    margin: 0 0 var(--space-3);
    line-height: 1;
  }
  .disclaimer {
    color: var(--text-muted);
    max-width: 60ch;
    margin-bottom: var(--space-2);
  }
  .colophon {
    margin-bottom: 0;
    max-width: 70ch;
  }
</style>
