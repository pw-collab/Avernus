---
import { render } from 'astro:content';
import EntityLayout from '../../layouts/EntityLayout.astro';
import SpoilerWrapper from '../../components/SpoilerWrapper.astro';
import { buildEntityPaths, buildJsonLd } from '../../lib/entityPages';

export async function getStaticPaths() {
  return buildEntityPaths('locations');
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const jsonLd = buildJsonLd('locations', entry, Astro.site);

const mdxComponents = { SpoilerWrapper };
---

<EntityLayout collection="locations" entry={entry} jsonLd={jsonLd}>
  <Content components={mdxComponents} />
</EntityLayout>
