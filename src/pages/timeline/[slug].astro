---
import { render } from 'astro:content';
import EntityLayout from '../../layouts/EntityLayout.astro';
import SpoilerWrapper from '../../components/SpoilerWrapper.astro';
import { buildEntityPaths, buildJsonLd } from '../../lib/entityPages';

export async function getStaticPaths() {
  return buildEntityPaths('timeline');
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const jsonLd = buildJsonLd('timeline', entry, Astro.site);

const mdxComponents = { SpoilerWrapper };
---

<EntityLayout collection="timeline" entry={entry} jsonLd={jsonLd}>
  <Content components={mdxComponents} />
</EntityLayout>
