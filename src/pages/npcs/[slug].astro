---
import { render } from 'astro:content';
import EntityLayout from '../../layouts/EntityLayout.astro';
import { buildEntityPaths, buildJsonLd } from '../../lib/entityPages';

export async function getStaticPaths() {
  return buildEntityPaths('npcs');
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const jsonLd = buildJsonLd('npcs', entry, Astro.site);
---

<EntityLayout collection="npcs" entry={entry} jsonLd={jsonLd}>
  <Content />
</EntityLayout>
