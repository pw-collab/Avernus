{
  "name": "avernus-archives",
  "type": "module",
  "version": "0.1.0",
  "description": "The Avernus Archives — a static, git-backed, structured-content wiki for the Ravenloft D&D campaign setting.",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist/client",
    "postbuild:index": "pagefind --site dist/client",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "check": "astro check",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@keystatic/astro": "^5.2.0",
    "@keystatic/core": "^0.5.51",
    "astro": "^7.1.0",
    "d3-force": "^3.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "pagefind": "^1.5.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.112.0"
  }
}
